---
import '../styles/global.css';
const { title = "Pixel Art Generator", description = "A purely client-side pixel art generator built with Astro and HTML5 Canvas." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		<script is:inline>
			const theme = localStorage.getItem('theme');
			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body class="bg-background text-foreground min-h-screen flex flex-col selection:bg-primary selection:text-canvas">
		<slot />
	</body>
</html>
